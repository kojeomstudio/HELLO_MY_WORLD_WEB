{
    "server": {
        "name": "HelloMyWorld Web Game Server",
        "version": "1.0.0",
        "description": "Web-based voxel game server ported from minetest_sub_project (Luanti)",
        "maxPlayers": 100,
        "tickRate": 20,
        "port": 5266
    },
    "world": {
        "worldGenerator": "v7",
        "defaultGenerator": "noise",
        "chunkSize": 16,
        "renderDistance": 4,
        "worldSeed": 12345,
        "generators": ["noise", "flat", "v5", "v7", "fractal", "singlenode"],
        "generateTrees": true,
        "generateCaves": true,
        "generateOres": true,
        "treeDensity": 0.02,
        "caveDensity": 0.5,
        "oreDensity": 0.3,
        "worldBorderSize": 1000
    },
    "mapgenV5": {
        "fillerDepthNoise": { "seed": 0, "octaves": 3, "persistence": 0.5, "spread": { "x": 150, "y": 150, "z": 150 } },
        "factorNoise": { "seed": 0, "octaves": 2, "persistence": 0.5, "spread": { "x": 150, "y": 150, "z": 150 } },
        "groundNoise3D": { "seed": 0, "octaves": 3, "persistence": 0.5, "spread": { "x": 80, "y": 80, "z": 80 } }
    },
    "mapgenFractal": {
        "fractal": 1,
        "iterations": 256,
        "scale": 40.0,
        "offsetX": 0.0,
        "offsetY": 0.0
    },
    "mapgenSinglenode": {
        "blockName": "air"
    },
    "player": {
        "defaultHealth": 20,
        "defaultBreath": 10,
        "respawnHealth": 20,
        "inventorySize": 32,
        "hotbarSize": 8,
        "fallDamageThreshold": 3.0,
        "fallDamageMultiplier": 1.0,
        "startItems": ["wooden_pickaxe", "wooden_sword", "wooden_axe", "wooden_shovel", "torch", "bread", "bucket"]
    },
    "physics": {
        "gravity": 9.81,
        "jumpForce": 6.5,
        "walkSpeed": 4.0,
        "sprintSpeed": 8.0,
        "flySpeed": 12.0,
        "terminalVelocity": 50.0,
        "drag": 0.1,
        "liquidDrag": 0.8,
        "climbSpeed": 3.0
    },
    "dayNight": {
        "cycleLength": 24000,
        "dawnStart": 4500,
        "dayStart": 6000,
        "duskStart": 16500,
        "nightStart": 18000
    },
    "network": {
        "protocolVersion": 1,
        "positionUpdateInterval": 50,
        "chunkCompression": true,
        "timeBroadcastInterval": 100
    },
    "liquid": {
        "waterFlowInterval": 3,
        "lavaFlowInterval": 5
    },
    "corsOrigins": ["http://localhost:5173", "http://localhost:3000"],
    "chatMessageLimitPer10Sec": 8,
    "chatMaxLength": 256,
    "itemEntityTTLSeconds": 900,
    "autoSaveIntervalTicks": 1200,
    "auth": {
        "pbkdf2Iterations": 100000,
        "saltSize": 16,
        "hashSize": 32,
        "minPasswordLength": 8,
        "maxPasswordLength": 128,
        "accountLockoutAttempts": 5,
        "accountLockoutMinutes": 5,
        "namePattern": "^[a-zA-Z0-9_-]{1,20}$",
        "reservedNames": ["server", "admin", "system", "console", "root", "moderator", "administrator", "owner", "staff", "operator"]
    },
    "security": {
        "enableHttpsRedirection": false,
        "hstsMaxAge": 31536000,
        "cspNonceSize": 16,
        "maxConcurrentConnections": 100,
        "profilerSecret": null
    },
    "gameLoop": {
        "autoSaveIntervalSeconds": 300,
        "autoBackupIntervalSeconds": 1800,
        "fallingBlockInterval": 10
    },
    "entities": {
        "maxEntities": 10000
    },
    "mobs": {
        "maxMobs": 50,
        "spawnInterval": 10.0,
        "despawnDistance": 128.0,
        "nightStart": 13000,
        "nightEnd": 23000,
        "darkLightThreshold": 7
    },
    "weather": {
        "minIntervalSeconds": 300,
        "maxIntervalSeconds": 600
    },
    "rollback": {
        "maxRecords": 10000
    },
    "areaProtection": {
        "maxAreasPerPlayer": 16,
        "maxClaimSize": 256
    },
    "antiCheat": {
        "maxSpeedBuffer": 1.5,
        "maxFlySpeedBuffer": 2.0,
        "positionCorrectionThreshold": 2.0,
        "maxViolationsBeforeCorrection": 3,
        "teleportDistanceThreshold": 50.0
    },
    "inventory": {
        "stackMaxSize": 64,
        "chestSize": 27
    },
    "knockback": {
        "baseValue": 8.0,
        "resistance": 0.17328,
        "horizontalMultiplier": 10.0,
        "verticalMultiplier": 8.0
    },
    "weatherProbabilities": {
        "night": { "none": 0.45, "rain": 0.30, "snow": 0.15, "thunderstorm": 0.10 },
        "duskDawn": { "none": 0.50, "rain": 0.25, "snow": 0.15, "thunderstorm": 0.10 },
        "day": { "none": 0.75, "rain": 0.15, "snow": 0.05, "thunderstorm": 0.05 }
    },
    "lighting": {
        "maxLight": 15,
        "emissionLevels": {
            "Torch": 14,
            "Lava": 14,
            "Glowstone": 15,
            "Fire": 15,
            "JackOLantern": 15,
            "RedstoneLamp": 12,
            "RedstoneTorch": 7,
            "Furnace": 13,
            "SeaLantern": 15,
            "Beacon": 15,
            "EndRod": 14
        }
    },
    "crops": {
        "wheatGrowTimeSeconds": 60,
        "carrotGrowTimeSeconds": 45,
        "potatoGrowTimeSeconds": 45,
        "waterProximityRadius": 4,
        "waterGrowthMultiplier": 4,
        "maxGrowthStage": 7
    },
    "weatherDetail": {
        "lightningStrikeRange": 100,
        "lightningDamageRange": 5.0,
        "lightningBaseDamage": 8.0
    },
    "explosions": {
        "defaultBlockResistance": 3.0,
        "waterLavaResistance": 100.0,
        "dropChance": 0.3,
        "playerKnockbackMultiplier": 0.5,
        "mobKnockbackMultiplier": 0.3
    },
    "dungeon": {
        "enabled": true,
        "minY": -32,
        "maxY": 8,
        "roomMinSize": 5,
        "roomMaxSize": 11,
        "roomHeight": 4,
        "corridorWidth": 2,
        "corridorHeight": 3,
        "roomsPerDungeon": 5,
        "chestChance": 0.5,
        "cobbleWallChance": 0.3,
        "mossWallChance": 0.2,
        "spawnInterval": 48,
        "maxDungeonsPerChunk": 1
    },
    "playerDamage": {
        "lavaDamageIntervalMs": 500,
        "blockDamageIntervalMs": 500,
        "saturationDrainPerTick": 0.01,
        "foodDrainPerTick": 0.05,
        "healthRegenThreshold": 18,
        "healthRegenPerTick": 0.2,
        "starvationDamagePerTick": 0.5,
        "drowningBreathDrain": 0.05,
        "drowningDamage": 1.0,
        "voidDeathY": -64,
        "respawnY": 80
    },
    "gameplay": {
        "startItems": {
            "torch": 16,
            "bread": 5,
            "coal": 8,
            "oak_planks": 16,
            "planks": 16,
            "stick": 8,
            "apple": 5
        },
        "experienceFormulaBase": 10,
        "experienceFormulaPerLevel": 5,
        "raycastMaxDistance": 8.0,
        "blockInteractDistance": 6.0,
        "positionBroadcastRange": 64,
        "chunkRequestDistanceLimit": 256
    },
    "tools": {
        "maxWear": 65536
    },
    "worldPersistence": {
        "maxBackups": 5,
        "maxForceloadedChunks": 256,
        "emergeMaxConcurrentPerTick": 4,
        "pregenerationRadius": 4
    }
}
