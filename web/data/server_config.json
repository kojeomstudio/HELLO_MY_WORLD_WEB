{
    "server": {
        "name": "HelloMyWorld Web Game Server",
        "version": "1.0.0",
        "description": "Web-based voxel game server ported from minetest_sub_project (Luanti)",
        "maxPlayers": 100,
        "tickRate": 20,
        "port": 5266
    },
    "world": {
        "worldGenerator": "v7",
        "defaultGenerator": "noise",
        "chunkSize": 16,
        "renderDistance": 4,
        "worldSeed": 12345,
        "generators": ["noise", "flat", "v5", "v7", "fractal", "singlenode"],
        "generateTrees": true,
        "generateCaves": true,
        "generateOres": true,
        "treeDensity": 0.02,
        "caveDensity": 0.5,
        "oreDensity": 0.3,
        "worldBorderSize": 1000
    },
    "mapgenV5": {
        "fillerDepthNoise": { "seed": 0, "octaves": 3, "persistence": 0.5, "spread": { "x": 150, "y": 150, "z": 150 } },
        "factorNoise": { "seed": 0, "octaves": 2, "persistence": 0.5, "spread": { "x": 150, "y": 150, "z": 150 } },
        "groundNoise3D": { "seed": 0, "octaves": 3, "persistence": 0.5, "spread": { "x": 80, "y": 80, "z": 80 } }
    },
    "mapgenFractal": {
        "fractal": 1,
        "iterations": 256,
        "scale": 40.0,
        "offsetX": 0.0,
        "offsetY": 0.0
    },
    "mapgenSinglenode": {
        "blockName": "air"
    },
    "player": {
        "defaultHealth": 20,
        "defaultBreath": 10,
        "respawnHealth": 20,
        "inventorySize": 32,
        "hotbarSize": 8,
        "fallDamageThreshold": 3.0,
        "fallDamageMultiplier": 1.0,
        "startItems": ["wooden_pickaxe", "wooden_sword", "wooden_axe", "wooden_shovel", "torch", "bread", "bucket"]
    },
    "physics": {
        "gravity": 9.81,
        "jumpForce": 6.5,
        "walkSpeed": 4.0,
        "sprintSpeed": 8.0,
        "flySpeed": 12.0,
        "terminalVelocity": 50.0,
        "drag": 0.1,
        "liquidDrag": 0.8,
        "climbSpeed": 3.0
    },
    "dayNight": {
        "cycleLength": 24000,
        "dawnStart": 4500,
        "dayStart": 6000,
        "duskStart": 16500,
        "nightStart": 18000
    },
    "network": {
        "protocolVersion": 1,
        "positionUpdateInterval": 50,
        "chunkCompression": true,
        "timeBroadcastInterval": 100
    },
    "liquid": {
        "waterFlowInterval": 3,
        "lavaFlowInterval": 5
    },
    "corsOrigins": ["http://localhost:5173", "http://localhost:3000"],
    "chatMessageLimitPer10Sec": 8,
    "chatMaxLength": 256,
    "itemEntityTTLSeconds": 900,
    "autoSaveIntervalTicks": 1200,
    "auth": {
        "pbkdf2Iterations": 100000,
        "saltSize": 16,
        "hashSize": 32,
        "minPasswordLength": 8,
        "maxPasswordLength": 128,
        "accountLockoutAttempts": 5,
        "accountLockoutMinutes": 5,
        "namePattern": "^[a-zA-Z0-9_-]{1,20}$",
        "reservedNames": ["server", "admin", "system", "console", "root", "moderator", "administrator", "owner", "staff", "operator"]
    },
    "security": {
        "enableHttpsRedirection": false,
        "hstsMaxAge": 31536000,
        "cspNonceSize": 16,
        "maxConcurrentConnections": 0
    }
}
